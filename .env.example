# =============================================================================
# VoxCPM2 Server - Environment Configuration Template
# =============================================================================
# Copy this file to .env and modify values:
#   cp .env.example .env
#
# Or auto-generate with strong API key:
#   bash init-env.sh
#
# DO NOT commit .env file to Git (already in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# API authentication key for X-API-Key header
# Generate strong key: openssl rand -hex 32
# Backend orchestrator must use the same key when calling this server
API_KEY=change-me-to-strong-random-string

# -----------------------------------------------------------------------------
# Server settings
# -----------------------------------------------------------------------------

# Bind address (0.0.0.0 = all interfaces, recommended for GPU server)
HOST=0.0.0.0

# Server port
PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Paths (relative to script directory or absolute)
# -----------------------------------------------------------------------------

# VoxCPM2 model weights location
# Will be downloaded here by setup.sh if not exists
MODEL_PATH=./models/VoxCPM2

# Voice library directory
VOICE_LIBRARY_DIR=./voice_library

# Generated audio outputs (temporary)
OUTPUTS_DIR=./outputs

# Cache for uploaded reference audios
CACHE_DIR=./cache

# -----------------------------------------------------------------------------
# Optional features
# -----------------------------------------------------------------------------

# Load denoiser model (uses ~1GB extra VRAM)
# Improves audio quality, but slower
LOAD_DENOISER=false

# -----------------------------------------------------------------------------
# Daemon mode (when using start.sh --daemon)
# -----------------------------------------------------------------------------

# Log file for daemon output
LOG_FILE=/var/log/voxcpm-server.log

# PID file to track daemon process
PID_FILE=/tmp/voxcpm-server.pid

# -----------------------------------------------------------------------------
# Advanced (rarely changed)
# -----------------------------------------------------------------------------

# HuggingFace mirror endpoint (faster for some regions)
# HF_ENDPOINT=https://hf-mirror.com

# CUDA device selection (if multiple GPUs)
# CUDA_VISIBLE_DEVICES=0

# Disable telemetry
# TRANSFORMERS_NO_ADVISORY_WARNINGS=1
# DO_NOT_TRACK=1
