# =============================================================================
# VoxCPM2 Server Configuration
# =============================================================================
# Copy this file to .env and modify values for your environment.
# DO NOT commit .env file to git.
# =============================================================================

# --- Required ---
# Generate strong API key: openssl rand -hex 32
API_KEY=change-me-to-strong-random-string

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Paths ---
MODEL_PATH=./models/VoxCPM2
VOICE_LIBRARY_DIR=./voice_library
OUTPUTS_DIR=./outputs
CACHE_DIR=./cache

# --- Optional features ---
# Set to "true" to load denoiser (uses more VRAM, ~1GB extra)
LOAD_DENOISER=false

# --- Daemon mode (when using --daemon flag) ---
LOG_FILE=/var/log/voxcpm-server.log
PID_FILE=/tmp/voxcpm-server.pid
